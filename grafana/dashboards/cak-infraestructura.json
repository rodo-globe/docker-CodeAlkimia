{
  "title": "CodeAlkimia — Infraestructura",
  "uid": "cak-infra",
  "schemaVersion": 39,
  "editable": true,
  "refresh": "30s",
  "time": { "from": "now-3h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "PostgreSQL",
      "gridPos": { "h": 5, "w": 4, "x": 0, "y": 0 },
      "targets": [ { "expr": "pg_up", "refId": "A" } ],
      "fieldConfig": {
        "defaults": {
          "mappings": [ { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } } ],
          "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 1 } ] }
        }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "SeaweedFS",
      "gridPos": { "h": 5, "w": 4, "x": 4, "y": 0 },
      "targets": [ { "expr": "up{job=\"seaweedfs\"}", "refId": "A" } ],
      "fieldConfig": {
        "defaults": {
          "mappings": [ { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } } ],
          "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 1 } ] }
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "OpenBao",
      "gridPos": { "h": 5, "w": 4, "x": 8, "y": 0 },
      "targets": [ { "expr": "up{job=\"openbao\"}", "refId": "A" } ],
      "fieldConfig": {
        "defaults": {
          "mappings": [ { "type": "value", "options": { "0": { "text": "DOWN / SELLADO", "color": "red" }, "1": { "text": "UP", "color": "green" } } } ],
          "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 1 } ] }
        }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "RAM del host",
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 0 },
      "targets": [ { "expr": "100 * (1 - node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)", "refId": "A" } ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 75 }, { "color": "red", "value": 90 } ] }
        }
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Disco libre (mínimo)",
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 0 },
      "targets": [ { "expr": "100 * min(node_filesystem_avail_bytes{fstype!~\"tmpfs|overlay\"} / node_filesystem_size_bytes{fstype!~\"tmpfs|overlay\"})", "refId": "A" } ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "yellow", "value": 10 }, { "color": "green", "value": 25 } ] }
        }
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "RAM por contenedor",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 5 },
      "targets": [ { "expr": "container_memory_working_set_bytes{name=~\"cak-.*\"}", "legendFormat": "{{name}}", "refId": "A" } ],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "CPU por contenedor",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 5 },
      "targets": [ { "expr": "rate(container_cpu_usage_seconds_total{name=~\"cak-.*\"}[5m])", "legendFormat": "{{name}}", "refId": "A" } ],
      "fieldConfig": { "defaults": { "unit": "percentunit" } }
    }
  ]
}
