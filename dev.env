# docker-CodeAlkimia — valores de DESARROLLO (descartables). NO usar en producción.
# dev-up.sh hace `cp dev.env .env` si `.env` falta, y compose lo auto-lee.
# Para producción: `cp prod.env .env` con valores reales (prod.env está gitignored).

# --- PostgreSQL ---
POSTGRES_DB=codealkimia
POSTGRES_USER=cak_user
POSTGRES_PASSWORD=password

# --- Grafana ---
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# --- SeaweedFS (object storage S3) ---
# Las credenciales S3 de dev viven en seaweedfs/s3.json (estáticas, de juguete).
# En producción el operador reemplaza ese archivo.
